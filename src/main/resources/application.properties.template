spring.application.name=nomPrenomClasseExamen
server.port=8089
### DATABASE ###
spring.datasource.url=jdbc:mysql://localhost:3306/ETAP_DB?createDatabaseIfNotExist=true
spring.datasource.username=root
spring.datasource.password=
### JPA / HIBERNATE ###
spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto= update

# JWT
application.security.jwt.secret-key=YOUR_JWT_SECRET_KEY_HERE
application.security.jwt.expiration=86400000

# Google OAuth2
spring.security.oauth2.client.registration.google.client-id=YOUR_GOOGLE_CLIENT_ID_HERE
spring.security.oauth2.client.registration.google.client-secret=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Mailing
application.mailing.frontend.activation-url=http://localhost:8089/auth/activate-account
application.mailing.frontend.reset-password-url=http://localhost:8089/reset-password
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=your-email@gmail.com
spring.mail.password=your-app-password
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.default-encoding=UTF-8

#Logging
logging.level.root = info
logging.pattern.console= %d{yyyy-MM-dd HH:mm:ss} -%level -%logger{60} %msg %n

fixer.api.key=YOUR_FIXER_API_KEY_HERE

# Open-Meteo
weather.open-meteo.forecast-url=https://api.open-meteo.com/v1/forecast
weather.open-meteo.historical-url=https://archive-api.open-meteo.com/v1/archive
weather.open-meteo.default-timezone=auto

# EIA Oil Price API (free key: https://www.eia.gov/opendata/register.php)
eia.api.key=YOUR_EIA_API_KEY_HERE
eia.api.base-url=https://api.eia.gov/v2

# Energy price derivation (gas from EIA Henry Hub, electricity = gas × multiplier)
energy.usd-mmbtu-to-eur-mwh=3.14
energy.electricity-gas-multiplier=2.8

# ML Microservice (Python Flask)
ml.service.base-url=http://localhost:5001
ml.auto-retrain-interval-minutes=60

# Groq
groq.api-key=YOUR_GROQ_API_KEY_HERE
groq.base-url=https://api.groq.com/openai/v1
groq.intent-model=llama-3.1-8b-instant
groq.answer-model=llama-3.3-70b-versatile
